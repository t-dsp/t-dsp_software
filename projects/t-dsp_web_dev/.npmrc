# Flatten node_modules (npm-style) instead of pnpm's nested .pnpm store.
#
# electron-builder's `portable`/`nsis` targets shell out to makensis.exe,
# an old Win32 tool that can't resolve !include paths longer than 260
# chars. pnpm's default `.pnpm/app-builder-lib@.../node_modules/...`
# layout blows past that limit (this is why the build previously used
# the `dir` target and shipped an unpacked folder instead of one .exe).
#
# Hoisting collapses app-builder-lib + its bundled NSIS templates to a
# short `node_modules/app-builder-lib/...` path, so makensis is happy and
# the single-file `portable` target builds. Scoped to this project only.
node-linker=hoisted
