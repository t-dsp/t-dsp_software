# Relay (server) — set these in Railway's Variables tab.
AUTH_USER=admin
AUTH_PASS=change-me-please
SESSION_SECRET=generate-a-long-random-string
DEVICE_TOKEN=generate-another-long-random-string
DEVICE_ID=mixer-1
# PORT is provided by Railway automatically.

# Agent (laptop) — set these where you run `pnpm agent`.
# RELAY_URL must be the wss:// public URL of your deployed relay.
RELAY_URL=wss://your-app.up.railway.app
# DEVICE_TOKEN must match the relay's DEVICE_TOKEN above.
# COM_PORT=COM4         # optional; auto-detects Teensy by VID/PID if unset
# BAUD=115200
