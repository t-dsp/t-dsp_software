{
  "schema_version": 1,
  "description": "Preset definitions for the TDspMPE virtual-analog synth engine. Each preset is a full parameter snapshot — the UI (Phase 2e) fires the corresponding OSC writes in a batch to load it onto the firmware. All numeric ranges match the firmware's clamps so loading a preset always produces a defined state.",
  "schema": {
    "waveform":          "int 0..3 — 0=saw, 1=square, 2=triangle, 3=sine (OSC /synth/mpe/waveform)",
    "attack_sec":        "float 0..10 — envelope attack in seconds (OSC /synth/mpe/attack)",
    "release_sec":       "float 0..10 — envelope release in seconds (OSC /synth/mpe/release)",
    "volume":            "float 0..1 — post-voice gain (OSC /synth/mpe/volume)",
    "filter_cutoff_hz":  "float 20..20000 — base filter cutoff before CC#74 modulation (OSC /synth/mpe/filter/cutoff)",
    "filter_resonance":  "float 0.707..5.0 — filter Q; 5.0 = self-oscillation (OSC /synth/mpe/filter/resonance)",
    "lfo_rate_hz":       "float 0..20 — LFO rate; 0 disables (OSC /synth/mpe/lfo/rate)",
    "lfo_depth":         "float 0..1 — LFO depth; 0 disables (OSC /synth/mpe/lfo/depth)",
    "lfo_dest":          "int 0..3 — 0=off, 1=cutoff, 2=pitch, 3=amp (OSC /synth/mpe/lfo/dest)",
    "lfo_waveform":      "int 0..3 — 0=sine, 1=triangle, 2=saw, 3=square (OSC /synth/mpe/lfo/waveform)"
  },
  "categories": {
    "retro":    { "color": "#ff6a00", "label": "Retro" },
    "emulating":{ "color": "#22aa66", "label": "Emulating" },
    "abstract": { "color": "#8844cc", "label": "Abstract" },
    "modern":   { "color": "#0088ff", "label": "Modern" }
  },
